# ============================================================
# Plantilla de variables de entorno — SGH Módulo Pacientes
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# Clave secreta de Django (genera una en: https://djecrety.ir/)
SECRET_KEY=tu_clave_secreta_aqui

# Modo de depuración (True en desarrollo, False en producción)
DEBUG=True

# Base de datos MySQL
DB_NAME=nombre_de_tu_base_de_datos
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_contraseña_mysql
DB_HOST=127.0.0.1
DB_PORT=3306
